-- Arsenal - Triggerbot (Otomatik Ateş Etme)
-- Executor: Synapse X, Krnl, Fluxus, ScriptWare
-- Çalışma prensibi: Nişan alınan oyuncunun üzerinde kırmızı isim göründüğünde otomatik ateş eder.

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local triggerActive = false
local mouse = LocalPlayer:GetMouse()

-- Triggerbot fonksiyonu
local function triggerBot()
    if not triggerActive then return end
    if not LocalPlayer.Character then return end
    
    local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    -- Arsenal'de silahlar genelde "Tool" altında olur
    local target = mouse.Target
    if target and target.Parent and target.Parent:FindFirstChild("Humanoid") then
        local player = Players:GetPlayerFromCharacter(target.Parent)
        if player and player ~= LocalPlayer then
            -- Ateş et
            mouse1click()
            wait(0.05)
        end
    end
end

-- Ctrl ile aç/kapa
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        triggerActive = not triggerActive
        if triggerActive then
            print("Triggerbot AÇIK (kırmızı isimli hedefe otomatik ateş eder)")
        else
            print("Triggerbot KAPALI")
        end
    end
end)

-- Sürekli kontrol
RunService.Heartbeat:Connect(function()
    triggerBot()
end)

print("Arsenal Triggerbot yüklendi! Ctrl ile AÇ/KAPA yapabilirsiniz.")
