-- ESP renk + hitbox güncelleme
local function updateESPAndHitbox()
    local sheriff = nil
    local killer = nil
    local innocents = {}
    local lobbyPlayers = {}
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local char = plr.Character
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                if tool.Name == "Sheriff" or tool.Name == "Gun" then
                    sheriff = plr
                elseif tool.Name == "Knife" then
                    killer = plr
                else
                    table.insert(innocents, plr)
                end
            else
                table.insert(lobbyPlayers, plr)
            end
        end
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and espData[plr] then
            local data = espData[plr]
            local bill = data.billboard
            local text = data.text
            local bg = data.bg
            local hitboxGroup = data.hitboxGroup
            
            local roleName = ""
            local color = COLORS.Default
            
            if plr == sheriff then
                roleName = "Şerif"
                color = COLORS.Sheriff
            elseif plr == killer then
                roleName = "Katil"
                color = COLORS.Killer
            elseif table.find(innocents, plr) then
                roleName = "Masum"
                color = COLORS.Innocent
            else
                roleName = "Lobi"
                color = COLORS.Lobby
            end
            
            if text then
                text.Text = plr.Name .. " [" .. roleName .. "]"
                text.TextColor3 = color
                if bg then
                    bg.BackgroundColor3 = color
                    bg.BackgroundTransparency = 0.5
                    bg.BorderColor3 = color
                end
            end
            
            if bill then
                bill.Enabled = features.ESP
            end
            
            -- Hitbox renklerini güncelle
            if hitboxGroup then
                for _, highlight in ipairs(hitboxGroup:GetChildren()) do
                    if highlight:IsA("Highlight") then
                        highlight.Enabled = features.ESP
                        highlight.FillColor = color
                        highlight.FillTransparency = 0.4
                        highlight.OutlineColor = color
                        highlight.OutlineTransparency = 0.2
                    end
                end
            end
        end
    end
end

-- AFK Farm (otomatik yürüme + silah toplama)
local afkRunning = false
local function startAFKFarm()
    if not LocalPlayer.Character then return end
    local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
    if not humanoid then return end
    afkRunning = true
    while features.AFKFork and afkRunning do
        if LocalPlayer.Character and humanoid then
            -- Rastgele yürü
            local randomDir = Vector3.new(math.random(-50, 50), 0, math.random(-50, 50))
            humanoid:MoveTo(LocalPlayer.Character.HumanoidRootPart.Position + randomDir)
            -- Otomatik silah topla (AutoPickup ile aynı)
            for _, item in ipairs(Workspace:GetDescendants()) do
                if item:IsA("Tool") and item:FindFirstChild("Handle") then
                    local dist = (item.Handle.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    if dist < 20 then
                        local remote = ReplicatedStorage:FindFirstChild("Remotes")
                        if remote then
                            local pickup = remote:FindFirstChild("PickupTool")
                            if pickup then pickup:FireServer(item) end
                        end
                        wait(0.1)
                    end
                end
            end
        end
        wait(0.5)
    end
end

-- Görünmez ol (Transparency + CanCollide false)
local function setInvisible(state)
    if not LocalPlayer.Character then return end
    for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
        if part:IsA("BasePart") then
            if state then
                part.Transparency = 1
                part.CanCollide = false
            else
                part.Transparency = 0
                part.CanCollide = true
            end
        end
    end
    if state then
        LocalPlayer.Character:FindFirstChild("Humanoid").WalkSpeed = 0
    else
        LocalPlayer.Character:FindFirstChild("Humanoid").WalkSpeed = 16
    end
end

-- Işınlanma (F3)
local function teleportToLocation(location)
    if not LocalPlayer.Character then return end
    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if features.Teleport then
        local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(root, tweenInfo, {CFrame = CFrame.new(location)})
        tween:Play()
    end
end

