-- Tüm özellikleri toplu aç/kapa (F2)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F2 then
        local allOn = true
        for _, state in pairs(features) do
            if not state then allOn = false end
        end
        for key in pairs(features) do
            features[key] = not allOn
        end
        for _, btnFrame in ipairs(frame:GetDescendants()) do
            if btnFrame:IsA("Frame") and btnFrame:FindFirstChildWhichIsA("TextButton") then
                local btn = btnFrame:FindFirstChildWhichIsA("TextButton")
                if btn then
                    local label = btn.Text:gsub("%s%[.*%]", "")
                    local key = label:gsub(" ", ""):gsub("(%u)(%l+)", function(a,b) return a..b end)
                    local found = false
                    for k in pairs(features) do
                        if label:find(k) or k:find(label) then
                            if features[k] then
                                btn.Text = label .. " [AÇIK]"
                                btn.TextColor3 = Color3.new(0.3, 1, 0.3)
                                btnFrame.BorderColor3 = Color3.new(0.3, 1, 0.3)
                            else
                                btn.Text = label .. " [KAPALI]"
                                btn.TextColor3 = Color3.new(1, 0.3, 0.3)
                                btnFrame.BorderColor3 = Color3.new(0.2, 0.2, 0.3)
                            end
                            found = true
                            break
                        end
                    end
                    if not found then
                        for k in pairs(features) do
                            if features[k] then
                                btn.Text = label .. " [AÇIK]"
                                btn.TextColor3 = Color3.new(0.3, 1, 0.3)
                                btnFrame.BorderColor3 = Color3.new(0.3, 1, 0.3)
                            else
                                btn.Text = label .. " [KAPALI]"
                                btn.TextColor3 = Color3.new(1, 0.3, 0.3)
                                btnFrame.BorderColor3 = Color3.new(0.2, 0.2, 0.3)
                            end
                            break
                        end
                    end
                end
            end
        end
    end
end)

-- ESP Billboard oluşturma (renkli)
local espBillboards = {}
local function createESP(plr)
    if plr == LocalPlayer then return end
    plr.CharacterAdded:Connect(function(char)
        wait(0.5)
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if char:FindFirstChild("ESP_Billboard") then char.ESP_Billboard:Destroy() end
        
        local bill = Instance.new("BillboardGui")
        bill.Name = "ESP_Billboard"
        bill.Size = UDim2.new(0, 220, 0, 60)
        bill.Adornee = root
        bill.StudsOffset = Vector3.new(0, 3.5, 0)
        bill.AlwaysOnTop = true
        bill.Enabled = false
        
        local text = Instance.new("TextLabel")
        text.Name = "ESP_Text"
        text.Text = plr.Name .. " [Bilinmiyor]"
        text.TextColor3 = COLORS.Default
        text.TextSize = 16
        text.BackgroundTransparency = 1
        text.Size = UDim2.new(1, 0, 1, 0)
        text.Font = Enum.Font.GothamBold
        text.TextStrokeTransparency = 0.5
        text.TextStrokeColor3 = Color3.new(0, 0, 0)
        text.Parent = bill
        
        -- İsim arka planı (renkli çerçeve)
        local bg = Instance.new("Frame")
        bg.Name = "ESP_BG"
        bg.Size = UDim2.new(1, 10, 1, 0)
        bg.Position = UDim2.new(0, -5, 0, 0)
        bg.BackgroundColor3 = Color3.new(0, 0, 0)
        bg.BackgroundTransparency = 0.6
        bg.BorderSizePixel = 2
        bg.Parent = bill
        
        bill.Parent = char
        espBillboards[plr] = bill
    end)
end

for _, plr in ipairs(Players:GetPlayers()) do
    createESP(plr)
end
Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(function(plr)
    espBillboards[plr] = nil
end)

-- ESP renk ve rol güncelleme
local function updateESPColors()
    -- Oyuncu rollerini belirle (MM2 mantığına göre)
    local sheriff = nil
    local killer = nil
    local innocents = {}
    local lobbyPlayers = {}
    
    -- Rol tespiti (oyun içi verilere göre - örnek mantık)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local char = plr.Character
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                if tool.Name == "Sheriff" or tool.Name == "Gun" then
                    sheriff = plr
                elseif tool.Name == "Knife" then
                    killer = plr
                else
                    table.insert(innocents, plr)
                end
            else
                table.insert(lobbyPlayers, plr)
            end
        end
    end
    
    -- ESP renklerini uygula
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and espBillboards[plr] then
            local bill = espBillboards[plr]
            local text = bill:FindFirstChild("ESP_Text")
            local bg = bill:FindFirstChild("ESP_BG")
            if text then
                local roleName = ""
                local color = COLORS.Default
                local bgColor = Color3.new(0, 0, 0)
                
                if plr == sheriff then
                    roleName = "Şerif"
                    color = COLORS.Sheriff
                    bgColor = COLORS.Sheriff
                elseif plr == killer then
                    roleName = "Katil"
                    color = COLORS.Killer
                    bgColor = COLORS.Killer
                elseif table.find(innocents, plr) then
                    roleName = "Masum"
                    color = COLORS.Innocent
                    bgColor = COLORS.Innocent
                else
                    roleName = "Lobi"
                    color = COLORS.Lobby
                    bgColor = COLORS.Lobby
                end
                
                text.Text = plr.Name .. " [" .. roleName .. "]"
                text.TextColor3 = color
                if bg then
                    bg.BackgroundColor3 = bgColor
                    bg.BackgroundTransparency = 0.5
                    bg.BorderColor3 = color
                end
                bill.Enabled = features.ESP
            end
        end
    end
end

-- Işınlanma fonksiyonu (F3 ile)
local function teleportToLocation(location)
    if not LocalPlayer.Character then return end
    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if features.Teleport then
        local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(root, tweenInfo, {CFrame = CFrame.new(location)})
        tween:Play()
    end
end

-- F3 ile ışınlanma menüsü
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F3 then
        if not features.Teleport then
            print("Işınlanma aktif değil! Önce butondan açın.")
            return
        end
        -- Haritadaki belirli noktalara ışınlanma (örnek konumlar)
        local locations = {
            ["Orta"] = Vector3.new(0, 3, 0),
            ["Köşe 1"] = Vector3.new(-30, 3, 30),
            ["Köşe 2"] = Vector3.new(30, 3, -30),
            ["Köşe 3"] = Vector3.new(-30, 3, -30),
            ["Köşe 4"] = Vector3.new(30, 3, 30),
            ["Yüksek"] = Vector3.new(0, 20, 0)
        }
        -- Basit menü: konsoldan yazdır
        print("=== IŞINLANMA KONUMLARI ===")
        print("1: Orta")
        print("2: Köşe 1")
        print("3: Köşe 2")
        print("4: Köşe 3")
        print("5: Köşe 4")
        print("6: Yüksek")
        print("Işınlanmak için sayı tuşlayın (1-6)")
        
        -- Klavye dinleme (basit)
        local connection
        connection = UserInputService.InputBegan:Connect(function(inp, gp)
            if gp then return end
            if inp.KeyCode == Enum.KeyCode.One then
                teleportToLocation(locations["Orta"])
            elseif inp.KeyCode == Enum.KeyCode.Two then
                teleportToLocation(locations["Köşe 1"])
            elseif inp.KeyCode == Enum.KeyCode.Three then
                teleportToLocation(locations["Köşe 2"])
            elseif inp.KeyCode == Enum.KeyCode.Four then
                teleportToLocation(locations["Köşe 3"])
            elseif inp.KeyCode == Enum.KeyCode.Five then
                teleportToLocation(locations["Köşe 4"])
            elseif inp.KeyCode == Enum.KeyCode.Six then
                teleportToLocation(locations["Yüksek"])
            else
                connection:Disconnect()
                return
            end
            connection:Disconnect()
        end)
    end
end)

-- ANA DÖNGÜ
RunService.Heartbeat:Connect(function()
    if not LocalPlayer.Character then return end
    local character = LocalPlayer.Character
    local humanoid = character:FindFirstChild("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not root then return end

    -- AutoGun
    if features.AutoGun then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            local remote = ReplicatedStorage:FindFirstChild("Remotes")
            if remote then
                local drop = remote:FindFirstChild("DropTool")
                if drop then drop:FireServer(tool) end
            end
        end
    end

    -- AutoPickup
    if features.AutoPickup then
        for _, item in ipairs(Workspace:GetDescendants()) do
            if item:IsA("Tool") and item:FindFirstChild("Handle") then
                local dist = (item.Handle.Position - root.Position).Magnitude
                if dist < 15 then
                    local remote = ReplicatedStorage:FindFirstChild("Remotes")
                    if remote then
                        local pickup = remote:FindFirstChild("PickupTool")
                        if pickup then pickup:FireServer(item) end
                    end
                    wait(0.05)
                end
            end
        end
    end

    -- AutoStab
    if features.AutoStab then
        local knife = character:FindFirstChildWhichIsA("Tool")
        if knife and knife.Name == "Knife" then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (plr.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist < 5 then
                        local remote = ReplicatedStorage:FindFirstChild("Remotes")
                        if remote then
                            local stab = remote:FindFirstChild("Stab")
                            if stab then stab:FireServer(knife, plr.Character.HumanoidRootPart) end
                        end
                        wait(0.15)
                    end
                end
            end
        end
    end

    -- ESP renk güncelleme (saniyede 2 kez)
    if features.ESP then
        updateESPColors()
    else
        for _, bill in pairs(espBillboards) do
            if bill then bill.Enabled = false end
        end
    end

    -- Speed
    if features.Speed then
        humanoid.WalkSpeed = 55
        humanoid.JumpPower = 85
    else
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
    end

    -- Noclip
    if features.Noclip then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    else
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end

    -- AutoDodge
    if features.AutoDodge then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local knife = plr.Character:FindFirstChildWhichIsA("Tool")
                if knife and knife.Name == "Knife" then
                    local dist = (plr.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist < 8 then
                        local away = (root.Position - plr.Character.HumanoidRootPart.Position).Unit * 15
                        humanoid:MoveTo(root.Position + away)
                    end
                end
            end
        end
    end
end)

