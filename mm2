-- Buton oluşturma fonksiyonu (kaliteli)
local function createButton(text, yPos, featureKey)
    local btnFrame = Instance.new("Frame")
    btnFrame.Size = UDim2.new(0.9, 0, 0, 35)
    btnFrame.Position = UDim2.new(0.05, 0, 0, yPos)
    btnFrame.BackgroundColor3 = Color3.new(0.15, 0.15, 0.2)
    btnFrame.BackgroundTransparency = 0.4
    btnFrame.BorderSizePixel = 1
    btnFrame.BorderColor3 = Color3.new(0.2, 0.2, 0.3)
    btnFrame.Parent = frame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btnFrame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Position = UDim2.new(0, 0, 0, 0)
    btn.Text = text .. " [KAPALI]"
    btn.TextColor3 = Color3.new(1, 0.3, 0.3)
    btn.TextSize = 14
    btn.BackgroundTransparency = 1
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = btnFrame
    
    btn.MouseButton1Click:Connect(function()
        features[featureKey] = not features[featureKey]
        if features[featureKey] then
            btn.Text = text .. " [AÇIK]"
            btn.TextColor3 = Color3.new(0.3, 1, 0.3)
            btnFrame.BorderColor3 = Color3.new(0.3, 1, 0.3)
        else
            btn.Text = text .. " [KAPALI]"
            btn.TextColor3 = Color3.new(1, 0.3, 0.3)
            btnFrame.BorderColor3 = Color3.new(0.2, 0.2, 0.3)
        end
    end)
    return btn
end

