-- MM2_Hile_Paneli.lua
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Tüm özelliklerin durumu
local features = {
    AutoGun = false,
    AutoPickup = false,
    AutoStab = false,
    ESP = false,
    Speed = false,
    Noclip = false,
    AutoDodge = false
}

-- GUI oluştur
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "MM2HilePanel"
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 250, 0, 300)
frame.Position = UDim2.new(0, 10, 0, 10)
frame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
frame.BackgroundTransparency = 0.3
frame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.Text = "MM2 Hile Paneli [F1 Kapat]"
title.TextColor3 = Color3.new(1, 1, 1)
title.BackgroundTransparency = 1
title.Parent = frame

-- Buton oluşturma fonksiyonu
local function createButton(text, yPos, featureKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 30)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.Text = text .. " [KAPALI]"
    btn.TextColor3 = Color3.new(1, 0, 0)
    btn.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
    btn.Parent = frame
    
    btn.MouseButton1Click:Connect(function()
        features[featureKey] = not features[featureKey]
        if features[featureKey] then
            btn.Text = text .. " [AÇIK]"
            btn.TextColor3 = Color3.new(0, 1, 0)
        else
            btn.Text = text .. " [KAPALI]"
            btn.TextColor3 = Color3.new(1, 0, 0)
        end
    end)
    return btn
end

createButton("AutoGun", 40, "AutoGun")
createButton("AutoPickup", 80, "AutoPickup")
createButton("AutoStab", 120, "AutoStab")
createButton("ESP", 160, "ESP")
createButton("Speed", 200, "Speed")
createButton("Noclip", 240, "Noclip")
createButton("AutoDodge", 280, "AutoDodge")

-- F1 ile paneli kapat/aç
local panelVisible = true
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F1 then
        panelVisible = not panelVisible
        frame.Visible = panelVisible
    end
end)
