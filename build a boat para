-- Build A Boat For Treasure - Sarı Takım İçin Otomatik Uç + Reset
-- Executor: Synapse X, Krnl, Fluxus, ScriptWare

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local flying = false
local targetZ = -1600  -- Map sonu Z koordinatı

-- Ana döngü
RunService.Heartbeat:Connect(function()
    if not flying then return end
    if not LocalPlayer.Character then return end
    
    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
    if not root or not humanoid then return end
    
    -- Uçma modu
    humanoid.PlatformStand = true
    
    -- Sarı takım pozisyonu: Z negatif yönde ilerle
    -- Sarı takım genelde başlangıçta Z=0 civarındadır, beyaz takım Z pozitif yönde gider
    local direction = Vector3.new(0, 0, -1)
    root.Velocity = direction * 100
    
    -- Map sonuna geldi mi kontrol et
    if root.Position.Z <= targetZ then
        humanoid.Health = 0
        flying = false
        print("Map sonu! Reset atıldı.")
        
        LocalPlayer.CharacterAdded:Connect(function()
            wait(1)
            if flying then return end
            flying = true
            print("Yeniden başlatıldı.")
        end)
    end
end)

-- Ctrl ile aç/kapa
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        flying = not flying
        if flying then
            print("Sarı takım otomatik uç AÇIK (Z negatif yönde)")
        else
            print("Otomatik uç KAPALI")
            if LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
                if root then root.Velocity = Vector3.new(0, 0, 0) end
                if humanoid then humanoid.PlatformStand = false end
            end
        end
    end
end)

print("Yüklendi! Ctrl ile AÇ/KAPA yapın. Sarı takım için Z negatif yönde uçar.")
