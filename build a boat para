local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local afkFarm = false
local farmLoop = nil

-- Para toplama fonksiyonu
local function collectMoney()
    if not LocalPlayer.Character then return end
    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- 1) Yerdeki paraları topla
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower():find("money") or obj.Name:lower():find("coin") or obj.Name:lower():find("cash") then
            local dist = (obj.Position - root.Position).Magnitude
            if dist < 20 then
                local remote = ReplicatedStorage:FindFirstChild("CollectMoney")
                if remote then
                    remote:FireServer(obj)
                    wait(0.05)
                end
            end
        end
    end
    
    -- 2) Oyuncunun evcil hayvanlarının topladıklarını al
    local pets = LocalPlayer:FindFirstChild("Pets")
    if pets then
        for _, pet in ipairs(pets:GetChildren()) do
            if pet:IsA("Model") then
                local remote = ReplicatedStorage:FindFirstChild("CollectPetMoney")
                if remote then
                    remote:FireServer(pet)
                    wait(0.05)
                end
            end
        end
    end
    
    -- 3) Görevleri otomatik yap (basit)
    local tasks = LocalPlayer.PlayerGui:FindFirstChild("Tasks")
    if tasks then
        for _, task in ipairs(tasks:GetChildren()) do
            if task:IsA("Frame") and task.Visible then
                -- Görev butonuna tıkla
                local button = task:FindFirstChild("CollectButton")
                if button and button:IsA("TextButton") then
                    button:FireServer()
                    wait(0.1)
                end
            end
        end
    end
end

-- AFK döngüsü
local function startAFKFarm()
    afkFarm = true
    print("AFK para kasma başladı...")
    while afkFarm do
        collectMoney()
        wait(1)
    end
end

-- Ctrl ile aç/kapa
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        afkFarm = not afkFarm
        if afkFarm then
            print("AFK para kasma AÇIK")
            if farmLoop then coroutine.close(farmLoop) end
            farmLoop = coroutine.create(startAFKFarm)
            coroutine.resume(farmLoop)
        else
            print("AFK para kasma KAPALI")
            if farmLoop then coroutine.close(farmLoop) end
            farmLoop = nil
        end
    end
end)

print("Adopt Me - AFK Otomatik Para Kasma yüklendi!")
