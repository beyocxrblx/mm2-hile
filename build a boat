end)

-- ========== ESP (Blok + Oyuncu) ==========
local espObjects = {}
local function createESP()
    -- Mevcut ESP'leri temizle
    for _, obj in ipairs(espObjects) do
        if obj and obj.Parent then obj:Destroy() end
    end
    espObjects = {}
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "Terrain" and obj.Parent ~= LocalPlayer.Character then
            -- Blok ESP (altın, tahta, demir vb.)
            if obj.Size.Magnitude > 2 and obj.Size.Magnitude < 50 then
                local box = Instance.new("BoxHandleAdornment")
                box.Size = obj.Size
                box.CFrame = obj.CFrame
                box.Color3 = Color3.new(0, 1, 1)
                box.Transparency = 0.4
                box.AlwaysOnTop = true
                box.ZIndex = 10
                box.Parent = obj
                table.insert(espObjects, box)
            end
        end
    end
end

-- ESP güncelleme (her 0.5 saniye)
local espTimer = 0
RunService.Heartbeat:Connect(function(dt)
    espTimer = espTimer + dt
    if espTimer > 0.5 and features.ESP then
        espTimer = 0
        createESP()
    elseif not features.ESP then
        for _, obj in ipairs(espObjects) do
            if obj and obj.Parent then obj:Destroy() end
        end
        espObjects = {}
    end
end)

-- ========== AUTO FARM (Blok Toplama) ==========
local function autoFarm()
    if not LocalPlayer.Character then return end
    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local character = LocalPlayer.Character
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local nearestBlock = nil
    local nearestDist = math.huge
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "Terrain" and obj.Parent ~= LocalPlayer.Character then
            if obj.Size.Magnitude > 2 and obj.Size.Magnitude < 50 then
                local dist = (obj.Position - root.Position).Magnitude
                if dist < nearestDist and dist > 5 then
                    nearestDist = dist
                    nearestBlock = obj
                end
            end
        end
    end
    
    if nearestBlock then
        humanoid:MoveTo(nearestBlock.Position + Vector3.new(0, 3, 0))
        -- Blok toplama (simule)
        local remote = ReplicatedStorage:FindFirstChild("CollectBlock")
        if remote then
            remote:FireServer(nearestBlock)
        end
    end
end

