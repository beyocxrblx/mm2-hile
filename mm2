local espData = {}
local function createESP(plr)
    if plr == LocalPlayer then return end
    plr.CharacterAdded:Connect(function(char)
        wait(0.5)
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if char:FindFirstChild("ESP_Billboard") then char.ESP_Billboard:Destroy() end
        
        -- Billboard (isim + rol)
        local bill = Instance.new("BillboardGui")
        bill.Name = "ESP_Billboard"
        bill.Size = UDim2.new(0, 240, 0, 70)
        bill.Adornee = root
        bill.StudsOffset = Vector3.new(0, 3.5, 0)
        bill.AlwaysOnTop = true
        bill.Enabled = false
        
        local text = Instance.new("TextLabel")
        text.Name = "ESP_Text"
        text.Text = plr.Name .. " [Bilinmiyor]"
        text.TextColor3 = COLORS.Default
        text.TextSize = 16
        text.BackgroundTransparency = 1
        text.Size = UDim2.new(1, 0, 1, 0)
        text.Font = Enum.Font.GothamBold
        text.TextStrokeTransparency = 0.5
        text.TextStrokeColor3 = Color3.new(0, 0, 0)
        text.Parent = bill
        
        local bg = Instance.new("Frame")
        bg.Name = "ESP_BG"
        bg.Size = UDim2.new(1, 10, 1, 0)
        bg.Position = UDim2.new(0, -5, 0, 0)
        bg.BackgroundColor3 = Color3.new(0, 0, 0)
        bg.BackgroundTransparency = 0.6
        bg.BorderSizePixel = 2
        bg.Parent = bill
        
        bill.Parent = char
        
        -- Hitbox çizgileri (Highlight)
        local hitboxGroup = Instance.new("Folder")
        hitboxGroup.Name = "Hitbox_ESP"
        hitboxGroup.Parent = char
        
        -- Vücut parçaları için Highlight (tüm uzuvlar)
        local parts = {"Head", "HumanoidRootPart", "LeftArm", "RightArm", "LeftLeg", "RightLeg", "UpperTorso", "LowerTorso"}
        for _, partName in ipairs(parts) do
            local part = char:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "Hitbox_" .. partName
                highlight.Adornee = part
                highlight.DepthMode = Enum.HighlightDepthMode.Occluded
                highlight.Enabled = false
                highlight.Parent = hitboxGroup
                table.insert(espData, {plr = plr, highlight = highlight, part = part})
            end
        end
        
        espData[plr] = {
            billboard = bill,
            hitboxGroup = hitboxGroup,
            text = text,
            bg = bg
        }
    end)
end

